# Restaurant Website Project - .gitignore

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment files - IMPORTANT: Keep these secure!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*token.json*
*credentials.json*

# Production builds
/build
/dist
build/
dist/

# Testing
/coverage
test_result.md

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# Development tools and caches
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Archive files
*.zip
*.tar.gz
*.tar
*.tgz
*.pack
*.deb
*.dmg

# Development specific folders
.emergent/
default-development/
.dist/

# Google Sheets credentials (if using service account)
google-credentials.json
service-account-key.json

# Database files (if using local DB)
*.db
*.sqlite
*.sqlite3

# Backup files
*.backup
*.bak 